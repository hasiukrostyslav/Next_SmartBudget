generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?      @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  accounts      Accounts[]
  Transaction   Transactions[]

  @@map("users")
}

model Accounts {
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refreshToken      String?  @map("refresh_token")
  accessToken       String?  @map("access_token")
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token")
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Transactions {
  transactionId       String              @id @default(cuid()) @map("transaction_id")
  userId              String              @map("user_id")
  transactionName     String              @map("transaction_name")
  transactionCategory TransactionCategory @map("transaction_category")
  paymentMethod       String              @map("payment_method")
  transactionType     TransactionType     @map("transaction_type")
  currency            Currency
  amount              Float
  description         String?
  status              TransactionStatus   @default(COMPLETED)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")
  user                Users               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

enum TransactionStatus {
  COMPLETED
  FAILED
  PENDING
  CANCELED
}

enum TransactionType {
  Income
  Expenses
}

enum Currency {
  UAH
  USD
  EUR
  PLN
  HUF
  GBP
}

enum TransactionCategory {
  income
  investments
  prize
  advertisement
  appliance
  books
  cafe
  car
  clothes
  delivery
  donations
  electricity
  entertainment
  flowers
  gas
  groceries
  healthcare
  insurance
  internet
  jewelry
  loan
  movies
  others
  repair
  sport
  taxes
  taxi
  transfer
  travel
  utilities
  water

  currency_exchange @map("currency exchange")
  mobile_phone      @map("mobile phone")
  personal_care     @map("personal care")
  pet_care          @map("pet care")
}
